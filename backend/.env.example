# Example environment file for deployment
# Copy this to .env and fill in your actual values

# Database (Supabase)
DB=mydatabase
DB_USER=myuser
DB_PASS=secret
SPRING_DATASOURCE_URL=jdbc:postgresql://<SUPABASE_HOST>:5432/postgres?user=postgres.[your-project]&password=[your-password]

# Cache (Upstash)
SPRING_REDIS_HOST=<UPSTASH_HOST>
SPRING_REDIS_PORT=<UPSTASH_PORT>
SPRING_REDIS_PASSWORD=<UPSTASH_PASSWORD>
SPRING_REDIS_SSL=true

# Elasticsearch
ELASTIC_PASS=elastic

# Mail Configuration
EMAIL_PROVIDER=resend
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=your-email@yourdomain.com

# SMTP Fallback Configuration (if EMAIL_PROVIDER=smtp)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-password
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_STARTTLS_ENABLE=true

# AWS Configuration
AWS_ACCESS_KEY=your-access-key
AWS_SECRET_KEY=your-secret-key
AWS_S3_BUCKET_NAME=your-bucket-name

# Frontend URL
FRONTEND_URL=http://localhost:5173

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
REDIS_KEY_SECRET=your-redis-key-secret-here

# JWT Keys (read from secrets volume)
JWT_PUBLIC_PEM_KEY=/run/secrets/public_key.pem
JWT_PRIVATE_PEM_KEY=/run/secrets/private_key.pem

# OAuth2 (if using)
OAUTH2_JWK_SET_URI=
OAUTH2_ISSUER_URI=

